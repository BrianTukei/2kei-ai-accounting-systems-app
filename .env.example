# ═══════════════════════════════════════════════════════
# 2K AI Accounting Systems — Environment Variables
# Copy to .env.local and fill in your values.
# NEVER commit .env.local to source control.
# ═══════════════════════════════════════════════════════

# ── Supabase ────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Stripe (international payments) ─────────────────────
# Get from https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Secret key — used ONLY in Supabase Edge Functions, not frontend
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Flutterwave (African markets) ────────────────────────
# Get from https://developer.flutterwave.com/
VITE_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-...
# Secret — for Edge Functions only
# FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-...

# ── Paystack (Nigeria/Ghana) ─────────────────────────────
# Get from https://dashboard.paystack.com/#/settings/developers
VITE_PAYSTACK_PUBLIC_KEY=pk_test_...
# Secret — for Edge Functions only
# PAYSTACK_SECRET_KEY=sk_test_...

# ── Application ──────────────────────────────────────────
# Full URL of your deployed app (used for payment redirects)
VITE_APP_URL=https://your-app.com

# ── Super Admin ───────────────────────────────────────────
# The Supabase user ID of the platform owner.
# Run this SQL to grant admin role:
#   INSERT INTO user_roles (user_id, role)
#   VALUES ('<your-user-id>', 'admin');
# The /super-admin route then becomes accessible.

# ── Optional: AI Provider ────────────────────────────────
# If you connect a real AI backend (OpenAI, Anthropic, etc.)
# VITE_AI_API_URL=https://your-ai-edge-function.supabase.co/functions/v1/ai-chat
# AI_API_KEY=sk-...   <-- Edge Function env var only, NOT VITE_

# ═══════════════════════════════════════════════════════
# Supabase Edge Functions env vars (set in Supabase dashboard)
# Project → Edge Functions → Secrets
# ═══════════════════════════════════════════════════════
# STRIPE_SECRET_KEY
# STRIPE_WEBHOOK_SECRET
# FLUTTERWAVE_SECRET_KEY
# PAYSTACK_SECRET_KEY
# SUPABASE_SERVICE_ROLE_KEY   (auto-injected by Supabase)
